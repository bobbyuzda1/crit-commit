{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Crit Commit Leaderboard Submission",
  "description": "Schema for community leaderboard submissions to Crit Commit RPG",
  "type": "object",
  "properties": {
    "characterName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "pattern": "^[a-zA-Z0-9\\s\\-_']+$",
      "description": "Player's character name (alphanumeric characters, spaces, hyphens, underscores, and apostrophes only)"
    },
    "level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20,
      "description": "Character level (1-20)"
    },
    "class": {
      "type": "string",
      "enum": ["Architect", "Scout", "Artificer", "Battlemage"],
      "description": "Character class"
    },
    "ascensionStars": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of ascension stars earned (prestige system)"
    },
    "zonesUnlocked": {
      "type": "integer",
      "minimum": 1,
      "maximum": 7,
      "description": "Number of zones unlocked (1-7, including Base Camp)"
    },
    "stackjackWins": {
      "type": "integer",
      "minimum": 0,
      "description": "Total Stackjack matches won"
    },
    "totalXP": {
      "type": "integer",
      "minimum": 0,
      "description": "Total experience points earned"
    },
    "narrativeExcerpt": {
      "type": "string",
      "maxLength": 500,
      "description": "Optional short excerpt from player's most memorable quest narrative (max 500 characters)"
    },
    "submittedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of submission"
    }
  },
  "required": [
    "characterName",
    "level",
    "class",
    "ascensionStars",
    "zonesUnlocked",
    "stackjackWins",
    "totalXP",
    "submittedAt"
  ],
  "additionalProperties": false
}